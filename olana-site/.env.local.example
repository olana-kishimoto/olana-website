# GitHubのPersonal Access Token
# 取得: GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
# 必要な権限: repo（すべて）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHubのユーザー名またはOrg名
GITHUB_OWNER=your-github-username

# リポジトリ名
GITHUB_REPO=olana-site

# 管理画面のパスワード（任意の文字列）
ADMIN_PASSWORD=your-secret-password
