# ===================================
# オルアナ Next.js 環境変数設定
# このファイルを .env.local にコピーして使用
# ===================================

# サイトURL（確認中はサブドメイン、本番切替後はolana.jp）
SITE_URL=https://new.olana.jp

# GitHub API（記事投稿・管理画面用）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=olana-kishimoto
GITHUB_REPO=olana-website

# 管理画面パスワード
ADMIN_PASSWORD=your-strong-password

# メール送信（XServerのSMTP）
SMTP_HOST=sv00000.xserver.jp
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@olana.jp
SMTP_PASS=your-email-password
NOTIFY_EMAIL=info@olana.jp
